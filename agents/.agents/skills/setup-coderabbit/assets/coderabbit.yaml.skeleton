# yaml-language-server: $schema=https://coderabbit.ai/integrations/schema.v2.json
# CodeRabbit configuration. Generated by the `setup-coderabbit` skill.
# Tune `reviews.path_instructions` and `tools` to match this repo. Do not
# change the flags in `reviews` below — they are intentional defaults.

language: en-US
early_access: false

reviews:
  profile: chill
  request_changes_workflow: true
  high_level_summary: false
  changed_files_summary: false
  sequence_diagrams: false
  estimate_code_review_effort: false
  suggested_labels: false
  suggested_reviewers: false
  in_progress_fortune: false
  poem: false

  review_status: true
  assess_linked_issues: true
  related_issues: true
  related_prs: true
  commit_status: true
  collapse_walkthrough: true

  auto_review:
    enabled: true
    auto_incremental_review: true
    drafts: false

  slop_detection:
    enabled: true

  # Markdown is intentionally excluded — we don't want CodeRabbit on docs.
  path_filters:
    - "!**/*.md"
    - "!**/*.mdx"

  pre_merge_checks:
    title:
      mode: warning
      requirements: |
        Title must state the user-facing change or fix in plain language.
        Avoid generic titles like "updates", "fixes", or "wip".
    description:
      mode: warning
    issue_assessment:
      mode: warning

  path_instructions:
    # One entry per stack detected in the repo. Replace these examples.
    #
    # - path: "backend/**"
    #   instructions: |
    #     Review against the stated intent in the PR description and any linked issue.
    #     Flag deviations from existing conventions for handlers, errors, and logging.
    #     Surface security risks: authn/authz, input validation, secrets, SSRF, SQLi.
    #     Flag migration safety, N+1 queries, and unbounded loops.
    #     Do NOT raise style nits — linters cover that.
    #
    # - path: "frontend/**"
    #   instructions: |
    #     Review against the stated intent in the PR description.
    #     Flag accessibility regressions, prop/typing changes that break callers,
    #     state-management leaks, secrets in client bundles.
    #     Do NOT raise style nits — linters cover that.
    #
    # - path: "infra/**/*.tf"
    #   instructions: |
    #     Flag blast radius: IAM scope, public ingress, deletions, encryption defaults.
    #     Flag missing required tags and unpinned providers.
    #     Do NOT raise style nits — tflint covers that.
    #
    # - path: ".github/workflows/**"
    #   instructions: |
    #     Flag secret handling, untrusted input in `run:` blocks, unpinned third-party
    #     actions (require SHA pins), and overly broad `permissions:` scopes.

tools:
  # Always on — secret scanning is non-negotiable.
  gitleaks:
    enabled: true

  # Enable only the linters that match the stacks present in this repo.
  # Remove the ones that don't apply. Defaults for everything else are fine.
  #
  # ruff:           { enabled: true }   # Python
  # eslint:         { enabled: true }   # JS / TS
  # biome:          { enabled: true }   # JS / TS
  # yamllint:       { enabled: true }   # YAML
  # markdownlint intentionally omitted — markdown is filtered out above.
  # actionlint:     { enabled: true }   # GitHub Actions
  # tflint:         { enabled: true }   # Terraform
  # checkov:        { enabled: true }   # Terraform / IaC security
  # trivy:          { enabled: true }   # Container / IaC / dependency scan
  # semgrep:        { enabled: true }   # Multi-language security
  # hadolint:       { enabled: true }   # Dockerfile
  # shellcheck:     { enabled: true }   # Shell

chat:
  auto_reply: true

knowledge_base:
  opt_out: false
  learnings:
    scope: auto
  issues:
    scope: auto
  pull_requests:
    scope: auto
