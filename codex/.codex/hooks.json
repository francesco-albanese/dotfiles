{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "~/.codex/hooks/block-npm-npx.sh"
          },
          {
            "type": "command",
            "command": "~/.codex/hooks/block-cat-sensitive.sh"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/protect-files-codex.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/run-langfuse-hook.sh"
          }
        ]
      }
    ]
  }
}
